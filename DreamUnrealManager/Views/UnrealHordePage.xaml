<Page
    x:Class="DreamUnrealManager.Views.UnrealHordePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:DreamUnrealManager.Models"
    xmlns:helpers="using:DreamUnrealManager.Helpers"
    mc:Ignorable="d">

    <Page.Resources>
        <helpers:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <Style x:Key="RegistryItemContainerStyle" TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style x:Key="RegistryCodeTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
        </Style>
    </Page.Resources>

    <Grid x:Name="ContentArea">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="24" Spacing="16">

                <!-- Page header -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Unreal Horde 管理"
                               Style="{StaticResource TitleTextBlockStyle}"
                               VerticalAlignment="Center" />
                    <Button Grid.Column="1"
                            Style="{StaticResource AccentButtonStyle}"
                            Click="RefreshAll_Click"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE72C;" FontSize="16" />
                            <TextBlock Text="刷新全部" />
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Card 1: 本机网络信息 -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="本机网络信息"
                                       Style="{StaticResource SubtitleTextBlockStyle}"
                                       VerticalAlignment="Center" />
                            <Button Grid.Column="1"
                                    Content="刷新IP"
                                    Click="RefreshIp_Click"
                                    VerticalAlignment="Center" />
                        </Grid>

                        <TextBlock x:Name="HostNameTextBlock"
                                   Text="主机名: -"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="LocalIpTextBlock"
                                   Text="本机IP: -"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- Card 2: Windows 服务控制 -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Windows 服务控制"
                                       Style="{StaticResource SubtitleTextBlockStyle}"
                                       VerticalAlignment="Center" />
                            <Button Grid.Column="1"
                                    Content="刷新服务状态"
                                    Click="RefreshServices_Click"
                                    VerticalAlignment="Center" />
                        </Grid>

                        <TextBlock Text="服务名称: Horde Agent / Horde Server。支持启动、暂停与继续。"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap" />

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Style="{StaticResource SubCardStyle}">
                                <StackPanel Spacing="8">
                                    <TextBlock x:Name="AgentServiceNameText"
                                               Text="Horde Agent"
                                               Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <TextBlock x:Name="AgentServiceStatusText"
                                               Text="状态: -"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button x:Name="StartAgentButton"
                                                Content="启动"
                                                Style="{StaticResource AccentButtonStyle}"
                                                MinWidth="80"
                                                Click="StartAgent_Click" />
                                        <Button x:Name="PauseOrContinueAgentButton"
                                                Content="暂停"
                                                MinWidth="80"
                                                Click="PauseOrContinueAgent_Click" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1"
                                    Style="{StaticResource SubCardStyle}">
                                <StackPanel Spacing="8">
                                    <TextBlock x:Name="ServerServiceNameText"
                                               Text="Horde Server"
                                               Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <TextBlock x:Name="ServerServiceStatusText"
                                               Text="状态: -"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button x:Name="StartServerButton"
                                                Content="启动"
                                                Style="{StaticResource AccentButtonStyle}"
                                                MinWidth="80"
                                                Click="StartServer_Click" />
                                        <Button x:Name="PauseOrContinueServerButton"
                                                Content="暂停"
                                                MinWidth="80"
                                                Click="PauseOrContinueServer_Click" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <TextBlock x:Name="ServiceActionTextBlock"
                                   Text="服务操作日志: 就绪"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- Card 3: 服务事件日志 -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="12">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="服务事件日志"
                                       Style="{StaticResource SubtitleTextBlockStyle}"
                                       VerticalAlignment="Center" />
                            <ToggleSwitch Grid.Column="1"
                                          x:Name="ServiceLogAutoRefreshSwitch"
                                          Header="自动刷新"
                                          IsOn="True"
                                          VerticalAlignment="Center"
                                          Toggled="ServiceLogAutoRefreshSwitch_Toggled" />
                            <Button Grid.Column="2"
                                    Content="刷新日志"
                                    Click="RefreshServiceLogs_Click"
                                    VerticalAlignment="Center" />
                        </Grid>

                        <TextBlock x:Name="ServiceLogStatusTextBlock"
                                   Text="事件日志: 未刷新"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap" />

                        <Border Style="{StaticResource SubCardStyle}">
                            <ListView x:Name="ServiceLogListView"
                                      SelectionMode="None"
                                      IsItemClickEnabled="False"
                                      MaxHeight="300">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                                   TextWrapping="Wrap"
                                                   FontFamily="Consolas"
                                                   Margin="0,2,0,2" />
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Card 4: Horde 注册表配置 -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Horde 注册表配置"
                                       Style="{StaticResource SubtitleTextBlockStyle}"
                                       VerticalAlignment="Center" />
                            <Button Grid.Column="1"
                                    Content="刷新注册表"
                                    Click="RefreshRegistry_Click"
                                    VerticalAlignment="Center" />
                        </Grid>

                        <Border Style="{StaticResource SubCardStyle}">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8">
                                <FontIcon Glyph="&#xE946;"
                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                          VerticalAlignment="Center" />
                                <TextBlock Text="可编辑项通过弹框修改并二次确认；不可编辑项不显示修改按钮。写入 HKLM 需要管理员权限。"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <ListView x:Name="RegistryListView"
                                  SelectionMode="None"
                                  IsItemClickEnabled="False"
                                  HorizontalAlignment="Stretch"
                                  ItemContainerStyle="{StaticResource RegistryItemContainerStyle}">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:HordeRegistryItem">
                                    <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="12">
                                        <Grid RowSpacing="8">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <StackPanel Grid.Row="0"
                                                        Spacing="4">
                                                <TextBlock Text="{x:Bind ValueName}"
                                                           FontFamily="Consolas"
                                                           FontSize="15"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{x:Bind FullPath}"
                                                           Style="{StaticResource RegistryCodeTextStyle}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>

                                            <Border Grid.Row="1"
                                                    Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="6"
                                                    Padding="8">
                                                <StackPanel Spacing="6">
                                                    <TextBlock Text="VALUE"
                                                               Style="{StaticResource RegistryCodeTextStyle}"
                                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                                    <TextBlock Text="{x:Bind CurrentValue, Mode=OneWay}"
                                                               FontFamily="Consolas"
                                                               TextWrapping="Wrap"
                                                               MinHeight="22"
                                                               VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Border>

                                            <Grid Grid.Row="2"
                                                  ColumnSpacing="10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0"
                                                           Text="修改会立即写入注册表并生效"
                                                           Style="{StaticResource RegistryCodeTextStyle}"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis" />

                                                <Button Grid.Column="1"
                                                        Content="修改值"
                                                        HorizontalAlignment="Right"
                                                        Tag="{x:Bind}"
                                                        Click="EditRegistryValue_Click"
                                                        Visibility="{x:Bind CanEdit, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
